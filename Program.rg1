raygen 1

module commerce.order_engine

use system.io
use system.math
use system.text
use system.time
use system.tables
use system.collections
use system.parallel
use system.memory


#[
    Raygen Commerce Order Engine

    Demonstrates:

    - Strong nominal types
    - Records, choices, listings, arrays, nests, tables, and trees
    - retain, store, dismiss, and free
    - allow and deny error handling
    - Direct mapping
    - Derivative ordering
    - Deductive reasoning
    - Case-based concurrency
    - Ordered-layer parallelism
    - Inherent sorting
    - Mathematical loops
    - Regions
    - Traits and implementations
]#


# ------------------------------------------------------------
# Domain types
# ------------------------------------------------------------

type ProductId = u256
type CustomerId = u256
type OrderId = u256

type Quantity = u32
where value > 0

type StockCount = u32

type Money = f64
where value >= 0.0

type Percentage = f64
where value >= 0.0 and value <= 100.0


choice ProductCategory
{
    electronics
    household
    food
    books
    clothing
    tools
    unknown
}


choice OrderStatus
{
    pending
    validating
    approved
    denied
    processing
    completed
}


choice PaymentMethod
{
    card
    bank
    wallet
    cash
}


choice OrderError
{
    product_missing(ProductId)
    insufficient_stock(ProductId, Quantity, StockCount)
    invalid_quantity(ProductId)
    invalid_customer(CustomerId)
    payment_denied(text)
    empty_order
    calculation_failure(text)
    storage_failure(text)
}


# ------------------------------------------------------------
# Core records
# ------------------------------------------------------------

record Product
{
    id: ProductId
    name: text
    category: ProductCategory
    price: Money
    stock: StockCount
    active: bool
}


record Customer
{
    id: CustomerId
    name: text
    email: text
    discount: Percentage
    active: bool
}


record OrderItem
{
    product_id: ProductId
    quantity: Quantity
}


record PricedItem
{
    product_id: ProductId
    product_name: text
    quantity: Quantity
    unit_price: Money
    line_total: Money
}


record Order
{
    id: OrderId
    customer_id: CustomerId
    items: listing<OrderItem>
    payment: PaymentMethod
    status: OrderStatus
}


record OrderTotals
{
    subtotal: Money
    discount: Money
    tax: Money
    shipping: Money
    grand_total: Money
}


record ProcessedOrder
{
    id: OrderId
    customer_name: text
    items: listing<PricedItem>
    totals: OrderTotals
    status: OrderStatus
    processed_at: u64
}


record InventoryChange
{
    product_id: ProductId
    previous_stock: StockCount
    quantity_removed: Quantity
    remaining_stock: StockCount
}


record OrderReport
{
    processed_count: u64
    denied_count: u64
    revenue: Money
    average_order_value: Money
    largest_order: Money
}


# ------------------------------------------------------------
# Configuration nest
# ------------------------------------------------------------

nest CommerceConfiguration
{
    taxation
    {
        rate: Percentage = 7.25
    }

    shipping
    {
        free_threshold: Money = 100.00
        standard_cost: Money = 8.95
    }

    processing
    {
        max_items_per_order: u32 = 128
        worker_count: u32 = 4
    }

    storage
    {
        report_path: text = "raygen_order_report.txt"
        audit_path: text = "raygen_order_audit.rgd"
    }
}


const CONFIGURATION: CommerceConfiguration =
{
    taxation
    {
        rate = 7.25
    }

    shipping
    {
        free_threshold = 100.00
        standard_cost = 8.95
    }

    processing
    {
        max_items_per_order = 128
        worker_count = 4
    }

    storage
    {
        report_path = "raygen_order_report.txt"
        audit_path = "raygen_order_audit.rgd"
    }
}


# ------------------------------------------------------------
# Typed tables
# ------------------------------------------------------------

table Products
{
    id: ProductId key
    name: text index
    category: ProductCategory index
    price: Money
    stock: StockCount
    active: bool
}


table Customers
{
    id: CustomerId key
    name: text
    email: text index
    discount: Percentage
    active: bool
}


table InventoryAudit
{
    order_id: OrderId index
    product_id: ProductId index
    previous_stock: StockCount
    quantity_removed: Quantity
    remaining_stock: StockCount
    timestamp: u64 index
}


# ------------------------------------------------------------
# Reporting tree
# ------------------------------------------------------------

record ReportNode
{
    title: text
    value: text
}


tree<ReportNode> report_tree =
{
    node ReportNode
    {
        title = "Commerce Report"
        value = ""
    }
}


# ------------------------------------------------------------
# Traits
# ------------------------------------------------------------

trait Printable
{
    function print(self) -> void
}


implement Printable for ProcessedOrder
{
    function print(self) -> void
    {
        emit "--------------------------------------------------"
        emit "Order: " + text(self.id)
        emit "Customer: " + self.customer_name
        emit "Status: " + text(self.status)
        emit "Processed at: " + text(self.processed_at)
        emit ""

        each item in self.items
        {
            emit
                item.product_name
                + " x"
                + text(item.quantity)
                + " @ $"
                + money_text(item.unit_price)
                + " = $"
                + money_text(item.line_total)
        }

        emit ""
        emit "Subtotal: $" + money_text(self.totals.subtotal)
        emit "Discount: $" + money_text(self.totals.discount)
        emit "Tax: $" + money_text(self.totals.tax)
        emit "Shipping: $" + money_text(self.totals.shipping)
        emit "Grand total: $" + money_text(self.totals.grand_total)
        emit "--------------------------------------------------"
    }
}


# ------------------------------------------------------------
# Formatting functions
# ------------------------------------------------------------

function money_text(value: Money) -> text
{
    return format_decimal(value, digits = 2)
}


function category_text(category: ProductCategory) -> text
{
    map category direct
    {
        electronics -> return "Electronics"
        household   -> return "Household"
        food        -> return "Food"
        books       -> return "Books"
        clothing    -> return "Clothing"
        tools       -> return "Tools"
        unknown     -> return "Unknown"
    }
}


